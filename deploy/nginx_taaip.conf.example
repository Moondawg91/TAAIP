# Example nginx site config for TAAIP
# Place as /etc/nginx/sites-available/taaip and symlink to sites-enabled
server {
    listen 80;
    server_name taaip.app example.taaip.app; # replace with your domain(s)

    # Redirect HTTP to HTTPS if TLS is configured (use certbot or similar)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name taaip.app; # replace with actual domain

    # SSL certs (Let's Encrypt or provided certs)
    ssl_certificate /etc/letsencrypt/live/taaip.app/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/taaip.app/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Static frontend files — optional if frontend served by nginx
    root /opt/TAAIP/apps/web/build;
    index index.html;

    location /static/ {
        alias /opt/TAAIP/apps/web/build/static/;
        expires 1d;
    }

    # Proxy API requests to backend app
    location /api/ {
        proxy_pass http://127.0.0.1:8001/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout 120s;
    }

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }
}
