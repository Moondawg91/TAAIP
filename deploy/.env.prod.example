# Example production environment variables for TAAIP
# Copy to /opt/TAAIP/.env or /opt/TAAIP/.env.prod and edit values

# Application
TAAIP_ENV=production
ALLOW_ORIGINS=["https://taaip.app"]
LOCAL_DEV_AUTH_BYPASS=0

# Database (using SQLite for small pilot). For robust production, use POSTGRES.
# This path should be persistent on the droplet and owned by the app user (e.g., `taaip`)
TAAIP_DB_PATH=/opt/TAAIP/data/taaip.sqlite3

# Export/storage directories
EXPORT_STORAGE_DIR=/opt/TAAIP/data/exports
UPLOADS_DIR=/opt/TAAIP/data/uploads

# Server
# If running behind nginx reverse proxy, bind to 127.0.0.1 and a high port
HOST=127.0.0.1
PORT=8001

# Uvicorn / Gunicorn options (if used)
WORKERS=2
# Set to 1 to avoid background migrations running unexpectedly
TAAIP_BACKFILL_ON_STARTUP=0

# Optional: set an admin token for protected deploy scripts
EXPORT_API_TOKEN=replace_me_secure_token
