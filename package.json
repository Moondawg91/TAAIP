{
  "name": "taaip-api-gateway",
  "version": "1.0.0",
  "description": "Express.js API Gateway for TAAIP",
  "main": "api-gateway.js",
  "type": "module",
  "scripts": {
    "start": "node api-gateway.js",
    "dev": "node --watch api-gateway.js",
    "api": "python -m uvicorn services.api.app.main:app --host 127.0.0.1 --port 8000 --reload",
    "web": "cd apps/web && npm start",
    "dev:all": "concurrently \"npm run api\" \"npm run web\""
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.4",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.9",
    "puppeteer": "^24.33.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.0.1"
  }
}
